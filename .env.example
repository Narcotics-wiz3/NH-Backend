# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY

# PayPal Configuration
PAYPAL_CLIENT_ID=sb_YOUR_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_SECRET
PAYPAL_MODE=sandbox

# M-Pesa Configuration (optional)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=

# Email Configuration (choose one approach)
# Option A: SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_REJECT_UNAUTHORIZED=true

# Option B: Email API Provider (e.g., SendGrid, Unione)
EMAIL_PROVIDER=unione
EMAIL_API_URL=
EMAIL_API_KEY=your_api_key_here

# Email Settings
EMAIL_FROM=no-reply@nyoderaheights.com
EMAIL_ENVELOPE_FROM=no-reply@nyoderaheights.com
EMAIL_SUBJECT=Nyodera Heights Notification
EMAIL_SUBJECT_OTP=Nyodera Heights Email Verification

# Server Port and Host
PORT=4242
HOST=0.0.0.0
FRONTEND_URL=https://panel.bwmxmd.co.ke
CORS_ALLOWED_ORIGINS=https://panel.bwmxmd.co.ke,http://localhost:3000,http://localhost:5173

# Database Configuration
DATABASE_URL=postgres://user:password@localhost:5432/nyoderaheights
DATABASE_SSL=false

# Important: Do NOT commit your real .env file with secrets to version control.
# Use this .env.example as a template for your local .env file.
